# This file contains a list of data generated by a Frame in one WebContent process
# that needs to be synchronized to other WebContent processes.
#
# See DocumentSyncData.in for a full description of the format.

FrameCanCreatePaymentSession : bool
FrameDocumentSecurityOrigin : RefPtr<WebCore::SecurityOrigin> [Headers=<WebCore/SecurityOrigin.h>]
FrameURLProtocol : String [Headers=<wtf/text/WTFString.h>]
FrameRect : WebCore::IntRect [Headers=<WebCore/IntRect.h>]

## Layout information for Intersection Observer

FrameLayoutViewportRect : WebCore::LayoutRect [Headers=<WebCore/LayoutRect.h>]

# Rectangle of the visible portion of the frame in its parent frame, in the coordinate space of the document of the parent frame
ChildrenFrameVisibleRectMap : HashMap<WebCore::FrameIdentifier, std::optional<WebCore::LayoutRect>> [Headers=<WebCore/LayoutRect.h>,<WebCore/FrameIdentifier.h>]
